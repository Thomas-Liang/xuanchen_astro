---
import '../styles/global.css';
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
		<meta http-equiv="Pragma" content="no-cache" />
		<meta http-equiv="Expires" content="0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="免费资源分享平台" />
		<title>免费资源导航</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="bg-pattern"></div>
		
		<header class="header">
			<div class="container">
				<a href="/xuanchen_astro/" class="logo">
					<span class="logo-icon">⬡</span>
					<span class="logo-text">资源集</span>
				</a>
				<nav class="nav">
					<a href="/xuanchen_astro/resources" class="nav-link">全部资源</a>
					<a href="/xuanchen_astro/cloud-storage" class="nav-link">网盘</a>
					<a href="/xuanchen_astro/tools" class="nav-link">工具</a>
					<a href="/xuanchen_astro/projects" class="nav-link">项目</a>
				</nav>
			</div>
		</header>

		<main class="main">
			<section class="hero">
				<div class="container">
					<div class="hero-badge">发现优质资源</div>
					<h1>免费资源<span class="gradient-text">一站式导航</span></h1>
					<p>精选网盘资源、开发工具、学习资料，让资源获取更简单</p>
					<div class="hero-stats">
						<div class="stat">
							<span class="stat-num">50+</span>
							<span class="stat-label">资源站点</span>
						</div>
						<div class="stat">
							<span class="stat-num">10+</span>
							<span class="stat-label">分类标签</span>
						</div>
						<div class="stat">
							<span class="stat-num">每日</span>
							<span class="stat-label">更新维护</span>
						</div>
					</div>
				</div>
			</section>

			<section class="categories">
				<div class="container">
					<div class="section-header">
						<h2>浏览分类</h2>
						<p>按类别快速找到你需要的内容</p>
					</div>
					<div class="category-grid">
						<a href="/xuanchen_astro/cloud-storage" class="category-card card-1">
							<div class="card-icon">☁️</div>
							<div class="card-content">
								<h3>网盘资源</h3>
								<p>阿里云、百度网盘等资源汇总</p>
							</div>
							<div class="card-arrow">→</div>
						</a>
						<a href="/xuanchen_astro/tools" class="category-card card-2">
							<div class="card-icon">🛠️</div>
							<div class="card-content">
								<h3>开发工具</h3>
								<p>效率工具、编辑器、插件推荐</p>
							</div>
							<div class="card-arrow">→</div>
						</a>
						<a href="/xuanchen_astro/learning" class="category-card card-3">
							<div class="card-icon">📖</div>
							<div class="card-content">
								<h3>学习资料</h3>
								<p>教程、文档、视频课程</p>
							</div>
							<div class="card-arrow">→</div>
						</a>
						<a href="/xuanchen_astro/projects" class="category-card card-4">
							<div class="card-icon">💻</div>
							<div class="card-content">
								<h3>开源项目</h3>
								<p>GitHub 精选开源项目</p>
							</div>
							<div class="card-arrow">→</div>
						</a>
					</div>
				</div>
			</section>

			<section class="resources">
				<div class="container">
					<div class="section-header">
						<h2>热门推荐</h2>
						<p>大家都在用的优质资源</p>
					</div>
					<div class="resource-grid">
						<article class="resource-card">
							<div class="resource-header">
								<div class="resource-icon" style="background: linear-gradient(135deg, #FF6B35, #F7931E);">A</div>
								<div class="resource-info">
									<h3>阿里云盘</h3>
									<span class="resource-tag">网盘</span>
								</div>
							</div>
							<p class="resource-desc">海量影视、学习资源分享空间</p>
							<a href="https://www.aliyundrive.com" target="_blank" class="resource-link">
								<span>访问网站</span>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
							</a>
						</article>
						<article class="resource-card">
							<div class="resource-header">
								<div class="resource-icon" style="background: linear-gradient(135deg, #000000, #333333);">N</div>
								<div class="resource-info">
									<h3>Notion</h3>
									<span class="resource-tag">工具</span>
								</div>
							</div>
							<p class="resource-desc">笔记与知识管理一体化平台</p>
							<a href="https://www.notion.so" target="_blank" class="resource-link">
								<span>访问网站</span>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
							</a>
						</article>
						<article class="resource-card">
							<div class="resource-header">
								<div class="resource-icon" style="background: linear-gradient(135deg, #6e5494, #8b5cf6);">G</div>
								<div class="resource-info">
									<h3>GitHub</h3>
									<span class="resource-tag">项目</span>
								</div>
							</div>
							<p class="resource-desc">全球最大开源代码托管平台</p>
							<a href="https://github.com" target="_blank" class="resource-link">
								<span>访问网站</span>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
							</a>
						</article>
						<article class="resource-card">
							<div class="resource-header">
								<div class="resource-icon" style="background: linear-gradient(135deg, #00C853, #69F0AE);">V</div>
								<div class="resource-info">
									<h3>Vercel</h3>
									<span class="resource-tag">托管</span>
								</div>
							</div>
							<p class="resource-desc">免费静态网站托管与部署</p>
							<a href="https://vercel.com" target="_blank" class="resource-link">
								<span>访问网站</span>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
							</a>
						</article>
						<article class="resource-card">
							<div class="resource-header">
								<div class="resource-icon" style="background: linear-gradient(135deg, #4285F4, #34A853);">G</div>
								<div class="resource-info">
									<h3>Google Fonts</h3>
									<span class="resource-tag">素材</span>
								</div>
							</div>
							<p class="resource-desc">免费字体资源库</p>
							<a href="https://fonts.google.com" target="_blank" class="resource-link">
								<span>访问网站</span>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
							</a>
						</article>
						<article class="resource-card">
							<div class="resource-header">
								<div class="resource-icon" style="background: linear-gradient(135deg, #00D4FF, #0055FF);">C</div>
								<div class="resource-info">
									<h3>Cloudflare</h3>
									<span class="resource-tag">CDN</span>
								</div>
							</div>
							<p class="resource-desc">免费CDN与DNS解析服务</p>
							<a href="https://www.cloudflare.com" target="_blank" class="resource-link">
								<span>访问网站</span>
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
							</a>
						</article>
					</div>
				</div>
			</section>
		</main>

		<footer class="footer">
			<div class="container">
				<p>© 2026 资源集 · 让优质资源触手可及</p>
			</div>
		</footer>
	</body>
</html>

<style>
	:root {
		--primary: #6366f1;
		--primary-light: #818cf8;
		--primary-dark: #4f46e5;
		--bg: #0a0a0f;
		--bg-card: #12121a;
		--bg-card-hover: #1a1a26;
		--text: #f8fafc;
		--text-muted: #64748b;
		--border: #1e293b;
		--gradient-1: linear-gradient(135deg, #6366f1, #8b5cf6);
		--gradient-2: linear-gradient(135deg, #f472b6, #c084fc);
		--gradient-3: linear-gradient(135deg, #22d3ee, #6366f1);
		--gradient-4: linear-gradient(135deg, #34d399, #22d3ee);
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	body {
		font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
		background: var(--bg);
		color: var(--text);
		line-height: 1.6;
		min-height: 100vh;
	}

	.bg-pattern {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: 
			radial-gradient(600px circle at 20% 30%, rgba(99, 102, 241, 0.18) 0%, transparent 50%),
			radial-gradient(600px circle at 80% 70%, rgba(139, 92, 246, 0.15) 0%, transparent 50%),
			radial-gradient(400px circle at 50% 90%, rgba(236, 72, 153, 0.1) 0%, transparent 40%);
		pointer-events: none;
		z-index: -1;
	}

	.bg-pattern::before {
		content: '';
		position: absolute;
		inset: 0;
		background: 
			repeating-linear-gradient(
				0deg,
				transparent,
				transparent 50px,
				rgba(99, 102, 241, 0.02) 50px,
				rgba(99, 102, 241, 0.02) 51px
			),
			repeating-linear-gradient(
				90deg,
				transparent,
				transparent 50px,
				rgba(99, 102, 241, 0.02) 50px,
				rgba(99, 102, 241, 0.02) 51px
			);
	}

	.container {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 24px;
	}

	.header {
		position: sticky;
		top: 0;
		z-index: 100;
		backdrop-filter: blur(20px);
		background: rgba(10, 10, 15, 0.85);
		border-bottom: 1px solid var(--border);
	}

	.header .container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 64px;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 10px;
		text-decoration: none;
	}

	.logo-icon {
		font-size: 28px;
		background: var(--gradient-1);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		filter: drop-shadow(0 0 12px rgba(99, 102, 241, 0.5));
	}

	.logo-text {
		font-size: 20px;
		font-weight: 700;
		color: var(--text);
	}

	.nav {
		display: flex;
		gap: 8px;
	}

	.nav-link {
		padding: 10px 18px;
		color: var(--text-muted);
		text-decoration: none;
		font-size: 14px;
		font-weight: 500;
		border-radius: 10px;
		transition: all 0.2s ease;
		position: relative;
	}

	.nav-link::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), transparent);
		border-radius: 10px;
		opacity: 0;
		transition: opacity 0.2s;
	}

	.nav-link:hover {
		color: var(--text);
		background: rgba(99, 102, 241, 0.15);
	}

	.nav-link:hover::before {
		opacity: 1;
	}

	.main {
		min-height: calc(100vh - 120px);
	}

	.hero {
		padding: 100px 0 60px;
		text-align: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 8px 16px;
		background: rgba(99, 102, 241, 0.1);
		border: 1px solid rgba(99, 102, 241, 0.3);
		border-radius: 24px;
		font-size: 13px;
		color: var(--primary-light);
		margin-bottom: 24px;
		animation: fadeInDown 0.6s ease-out;
	}

	.hero h1 {
		font-size: 56px;
		font-weight: 700;
		line-height: 1.15;
		margin-bottom: 20px;
		letter-spacing: -0.03em;
		animation: fadeInUp 0.6s ease-out 0.1s both;
	}

	.hero p {
		font-size: 18px;
		color: var(--text-muted);
		max-width: 520px;
		margin: 0 auto 48px;
		animation: fadeInUp 0.6s ease-out 0.2s both;
	}

	.hero-stats {
		display: flex;
		justify-content: center;
		gap: 64px;
		animation: fadeInUp 0.6s ease-out 0.3s both;
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes fadeInDown {
		from {
			opacity: 0;
			transform: translateY(-20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		padding: 6px 14px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 20px;
		font-size: 13px;
		color: var(--text-muted);
		margin-bottom: 20px;
	}

	.hero h1 {
		font-size: 48px;
		font-weight: 700;
		line-height: 1.2;
		margin-bottom: 16px;
		letter-spacing: -0.02em;
	}

	.gradient-text {
		background: linear-gradient(135deg, #818cf8, #c084fc, #f472b6);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero p {
		font-size: 18px;
		color: var(--text-muted);
		max-width: 500px;
		margin: 0 auto 40px;
	}

	.hero-stats {
		display: flex;
		justify-content: center;
		gap: 48px;
	}

	.stat {
		text-align: center;
		position: relative;
	}

	.stat::before {
		content: '';
		position: absolute;
		top: -12px;
		left: 50%;
		transform: translateX(-50%);
		width: 40px;
		height: 2px;
		background: linear-gradient(90deg, transparent, var(--primary), transparent);
		border-radius: 2px;
	}

	.stat-num {
		display: block;
		font-size: 32px;
		font-weight: 700;
		background: linear-gradient(135deg, #f8fafc 0%, #c084fc 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin-bottom: 4px;
	}

	.stat-label {
		font-size: 13px;
		color: var(--text-muted);
		letter-spacing: 0.5px;
	}

	.section-header {
		text-align: center;
		margin-bottom: 48px;
	}

	.section-header h2 {
		font-size: 32px;
		font-weight: 600;
		margin-bottom: 10px;
		background: linear-gradient(135deg, #f8fafc 0%, #94a3b8 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.section-header p {
		color: var(--text-muted);
		font-size: 15px;
	}

	.categories {
		padding: 20px 0 60px;
	}

	.category-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
	}

	.category-card {
		animation: fadeInUp 0.5s ease-out both;
	}

	.card-1 { animation-delay: 0.1s; }
	.card-2 { animation-delay: 0.2s; }
	.card-3 { animation-delay: 0.3s; }
	.card-4 { animation-delay: 0.4s; }

	.category-card {
		display: flex;
		align-items: center;
		gap: 16px;
		padding: 24px;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 20px;
		text-decoration: none;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		overflow: hidden;
	}

	.category-card::before {
		content: '';
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 50%);
		opacity: 0;
		transition: opacity 0.3s;
	}

	.category-card:hover::before {
		opacity: 1;
	}

	.category-card:hover {
		transform: translateY(-4px);
		border-color: var(--primary-light);
		box-shadow: 
			0 20px 40px rgba(0,0,0,0.4),
			0 0 60px rgba(99, 102, 241, 0.15),
			inset 0 1px 0 rgba(255,255,255,0.1);
	}

	.card-icon {
		font-size: 32px;
		width: 56px;
		height: 56px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--bg);
		border-radius: 12px;
	}

	.card-1:hover .card-icon { background: linear-gradient(135deg, rgba(255,107,53,0.2), rgba(247,147,30,0.1)); }
	.card-2:hover .card-icon { background: linear-gradient(135deg, rgba(34,211,238,0.2), rgba(99,102,241,0.1)); }
	.card-3:hover .card-icon { background: linear-gradient(135deg, rgba(244,114,182,0.2), rgba(192,132,252,0.1)); }
	.card-4:hover .card-icon { background: linear-gradient(135deg, rgba(52,211,153,0.2), rgba(34,211,238,0.1)); }

	.card-content {
		flex: 1;
	}

	.card-content h3 {
		font-size: 17px;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 4px;
	}

	.card-content p {
		font-size: 13px;
		color: var(--text-muted);
	}

	.card-arrow {
		font-size: 20px;
		color: var(--text-muted);
		transition: transform 0.2s;
	}

	.category-card:hover .card-arrow {
		transform: translateX(4px);
		color: var(--primary-light);
	}

	.resources {
		padding: 20px 0 80px;
	}

	.resource-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
	}

	.resource-card {
		animation: fadeInUp 0.5s ease-out both;
	}

	.resource-card:nth-child(1) { animation-delay: 0.15s; }
	.resource-card:nth-child(2) { animation-delay: 0.25s; }
	.resource-card:nth-child(3) { animation-delay: 0.35s; }
	.resource-card:nth-child(4) { animation-delay: 0.45s; }
	.resource-card:nth-child(5) { animation-delay: 0.55s; }
	.resource-card:nth-child(6) { animation-delay: 0.65s; }

	.resource-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 24px;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		overflow: hidden;
	}

	.resource-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
	}

	.resource-card:hover {
		border-color: rgba(99, 102, 241, 0.5);
		transform: translateY(-6px);
		box-shadow: 
			0 24px 48px rgba(0,0,0,0.4),
			0 0 80px rgba(99, 102, 241, 0.12),
			inset 0 1px 0 rgba(255,255,255,0.08);
	}

	.resource-header {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 16px;
	}

	.resource-icon {
		width: 44px;
		height: 44px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 18px;
		font-weight: 700;
		color: white;
	}

	.resource-info h3 {
		font-size: 16px;
		font-weight: 600;
	}

	.resource-tag {
		font-size: 12px;
		color: var(--text-muted);
		background: var(--bg);
		padding: 2px 8px;
		border-radius: 4px;
	}

	.resource-desc {
		font-size: 14px;
		color: var(--text-muted);
